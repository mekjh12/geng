  const totalM  = totalKm * 1000;

  const latIdx = Math.min(90, Math.round(Math.abs(centerLat)));
  const mpp    = METERS_PER_PIXEL_BY_LAT[latIdx];

  const tileM  = MAPBOX_TILE_PX * mpp;
  const tilesN = Math.ceil(totalM / tileM) + 1;

  const half     = totalKm / 2;
  const centerPt = turf.point([centerLng, centerLat]);
  const nwLng = turf.destination(centerPt, half, 270, { units: 'kilometers' }).geometry.coordinates[0];
  const nwLat = turf.destination(centerPt, half,   0, { units: 'kilometers' }).geometry.coordinates[1];
  const seLng = turf.destination(centerPt, half,  90, { units: 'kilometers' }).geometry.coordinates[0];
  const seLat = turf.destination(centerPt, half, 180, { units: 'kilometers' }).geometry.coordinates[1];

  const startX = long2tile(nwLng, FETCH_ZOOM);
  const startY = lat2tile(nwLat,  FETCH_ZOOM);

  const tileList = [];
  for (let ty = 0; ty < tilesN; ty++)
    for (let tx = 0; tx < tilesN; tx++)
      tileList.push({ tx: startX + tx, ty: startY + ty, col: tx, row: ty });

  document.getElementById('loading-sub').textContent =
    `버퍼1: ${tilesN}×${tilesN} = ${tilesN*tilesN}장 다운로드 중...`;

  const pixelMap = new Map();
  await Promise.all(tileList.map(async ({ tx, ty, col, row }) => {
    const url = `https://api.mapbox.com/v4/mapbox.terrain-rgb/${FETCH_ZOOM}/${tx}/${ty}@2x.pngraw?access_token=${MAPBOX_TOKEN}`;
    try {
      pixelMap.set(`${col},${row}`, await downloadPngToPixels(url));
    } catch(e) {
      console.warn(`타일 ${tx},${ty} 실패:`, e.message);
    }
  }));

  const rawSize = tilesN * MAPBOX_TILE_PX;
  const rawBuf  = new Int32Array(rawSize * rawSize);
  for (let row = 0; row < tilesN; row++) {
    for (let col = 0; col < tilesN; col++) {
      const px = pixelMap.get(`${col},${row}`);
      if (!px) continue;
      const ox = col * MAPBOX_TILE_PX;
      const oy = row * MAPBOX_TILE_PX;
      for (let y = 0; y < MAPBOX_TILE_PX; y++)
        for (let x = 0; x < MAPBOX_TILE_PX; x++) {
          const si = (y * MAPBOX_TILE_PX + x) * 4;
          rawBuf[(oy+y)*rawSize + (ox+x)] = rgbToVal(px[si], px[si+1], px[si+2]);
        }
    }
  }

  const nwTileXf = lng2tileF(nwLng, FETCH_ZOOM);
  const nwTileYf = lat2tileF(nwLat, FETCH_ZOOM);
  const seTileXf = lng2tileF(seLng, FETCH_ZOOM);
  const seTileYf = lat2tileF(seLat, FETCH_ZOOM);

  const cropX0  = tileF2px(nwTileXf, startX);
  const cropY0  = tileF2px(nwTileYf, startY);
  const cropX1  = tileF2px(seTileXf, startX);
  const cropY1  = tileF2px(seTileYf, startY);
  const cropPxW = cropX1 - cropX0;
  const cropPxH = cropY1 - cropY0;

  document.getElementById('loading-sub').textContent =
    `버퍼1: crop(${cropX0.toFixed(1)},${cropY0.toFixed(1)})~(${cropX1.toFixed(1)},${cropY1.toFixed(1)}) → 1024×1024 bicubic...`;

  const buf1 = new Int32Array(OUTPUT_PX * OUTPUT_PX);
  for (let oy = 0; oy < OUTPUT_PX; oy++) {
    for (let ox = 0; ox < OUTPUT_PX; ox++) {
      const srcX = cropX0 + ox * cropPxW / (OUTPUT_PX - 1);
      const srcY = cropY0 + oy * cropPxH / (OUTPUT_PX - 1);
      const ix = Math.floor(srcX), iy = Math.floor(srcY);
      const dx = srcX - ix, dy = srcY - iy;
      let val = 0;
      for (let m = -1; m <= 2; m++) {
        const wy = cubicWeight(m - dy);
        if (wy === 0) continue;
        for (let n = -1; n <= 2; n++) {
          const cx = Math.max(0, Math.min(rawSize - 1, ix + n));
          const cy = Math.max(0, Math.min(rawSize - 1, iy + m));
          val += rawBuf[cy * rawSize + cx] * cubicWeight(n - dx) * wy;
        }
      }
      buf1[oy * OUTPUT_PX + ox] = Math.max(0, Math.min(16777215, Math.round(val)));
    }
  }

  return { buf1, mpp };
}

// ─── STEP2: 버퍼2 (GRID_N×1024 × GRID_N×1024) bicubic 업샘플 ──
function buildBuffer2(buf1, gridN) {
  const buf2Size = gridN * OUTPUT_PX;
  const buf2     = new Int32Array(buf2Size * buf2Size);

  function sampleBuf1(sx, sy) {
    const cx = Math.max(0, Math.min(OUTPUT_PX-1, Math.round(sx)));
    const cy = Math.max(0, Math.min(OUTPUT_PX-1, Math.round(sy)));
    return buf1[cy*OUTPUT_PX + cx];
  }

  for (let oy = 0; oy < buf2Size; oy++) {
    for (let ox = 0; ox < buf2Size; ox++) {
      const srcX = ox * (OUTPUT_PX-1) / (buf2Size-1);
      const srcY = oy * (OUTPUT_PX-1) / (buf2Size-1);
      const ix = Math.floor(srcX), iy = Math.floor(srcY);
      const dx = srcX-ix, dy = srcY-iy;
      let val = 0;
      for (let m = -1; m <= 2; m++) {
        const wy = cubicWeight(m-dy);
        if (wy === 0) continue;
        for (let n = -1; n <= 2; n++)
          val += sampleBuf1(ix+n, iy+m) * cubicWeight(n-dx) * wy;
      }
      buf2[oy*buf2Size + ox] = Math.max(0, Math.min(16777215, Math.round(val)));
    }
  }
  return { buf2, buf2Size };
}

// ─── STEP3: Gaussian blur ────────────────────────────────
function applyGaussian(buf2, buf2Size) {
  const SIGMA  = 3.0;
  const RADIUS = Math.ceil(SIGMA * 3);
  const KSIZE  = RADIUS * 2 + 1;
  const kernel = new Float32Array(KSIZE);
  let sum = 0;
  for (let i = 0; i < KSIZE; i++) {
    kernel[i] = Math.exp(-((i-RADIUS)**2) / (2*SIGMA*SIGMA));
    sum += kernel[i];
  }
  for (let i = 0; i < KSIZE; i++) kernel[i] /= sum;

  const tmp = new Float32Array(buf2Size * buf2Size);
  for (let y = 0; y < buf2Size; y++)
    for (let x = 0; x < buf2Size; x++) {
      let s = 0;
      for (let k = -RADIUS; k <= RADIUS; k++)
        s += buf2[y*buf2Size + Math.max(0,Math.min(buf2Size-1,x+k))] * kernel[k+RADIUS];
      tmp[y*buf2Size + x] = s;
    }
  for (let y = 0; y < buf2Size; y++)
    for (let x = 0; x < buf2Size; x++) {
      let s = 0;
      for (let k = -RADIUS; k <= RADIUS; k++)
        s += tmp[Math.max(0,Math.min(buf2Size-1,y+k))*buf2Size + x] * kernel[k+RADIUS];
      buf2[y*buf2Size + x] = Math.max(0, Math.min(16777215, Math.round(s)));
    }
}

// ─── STEP4: 버퍼2에서 타일 1개 추출 (Y플립) ─────────────
function extractTile(buf2, buf2Size, gridRow, gridCol) {
  const output = new Int32Array(OUTPUT_PX * OUTPUT_PX);
  const ox = gridCol * OUTPUT_PX;
  const oy = gridRow * OUTPUT_PX;
  let minVal = Infinity, maxVal = -Infinity;

  for (let y = 0; y < OUTPUT_PX; y++) {
    for (let x = 0; x < OUTPUT_PX; x++) {
      const v = buf2[(oy+y)*buf2Size + (ox+x)];
      output[(OUTPUT_PX-1-y)*OUTPUT_PX + x] = v;
      if (v > maxVal) maxVal = v;
      if (v < minVal) minVal = v;
    }
  }

  return {
    output,
    minM: (minVal - 100000) / 10,
    maxM: (maxVal - 100000) / 10,
  };
}

// ─── 노말맵 (Sobel) ──────────────────────────────────────
function generateNormalMap(output, size, metersPerPixel = 1.0) {
  const bytes = new Uint8Array(size * size * 3);
  const hAt = (x, y) => {
    const cx = Math.max(0, Math.min(size-1, x));
    const cy = Math.max(0, Math.min(size-1, y));
    return (output[cy*size + cx] - 100000) / 10;
  };
  for (let y = 0; y < size; y++) {
    for (let x = 0; x < size; x++) {
      const dX = (-hAt(x-1,y-1)+hAt(x+1,y-1)-hAt(x-1,y)*2+hAt(x+1,y)*2-hAt(x-1,y+1)+hAt(x+1,y+1)) / (8*metersPerPixel);
      const dY = (-hAt(x-1,y-1)-hAt(x,y-1)*2-hAt(x+1,y-1)+hAt(x-1,y+1)+hAt(x,y+1)*2+hAt(x+1,y+1)) / (8*metersPerPixel);
      const nx=-dX, ny=-dY, nz=1.0;
      const len=Math.sqrt(nx*nx+ny*ny+nz*nz);
      const i=(y*size+x)*3;
      bytes[i]  =Math.round(((nx/len)*0.5+0.5)*255);
      bytes[i+1]=Math.round(((ny/len)*0.5+0.5)*255);
      bytes[i+2]=Math.round(((nz/len)*0.5+0.5)*255);
    }
  }
  return bytes;
}

// ─── 타일 파일 블롭 생성 ─────────────────────────────────
async function makeTileFiles(output, format, mpp) {
  const normalBytes = generateNormalMap(output, OUTPUT_PX, mpp);
  const normalBlob  = new Blob([normalBytes], { type: 'application/octet-stream' });

  const LOW_PX    = 128;
  const lowOutput = new Int32Array(LOW_PX * LOW_PX);
  const lowBytes  = new Uint8Array(LOW_PX * LOW_PX * 3);
  for (let oy = 0; oy < LOW_PX; oy++) {
    for (let ox = 0; ox < LOW_PX; ox++) {
      const srcX = ox*(OUTPUT_PX-1)/(LOW_PX-1), srcY = oy*(OUTPUT_PX-1)/(LOW_PX-1);
      const ix=Math.floor(srcX), iy=Math.floor(srcY), dx=srcX-ix, dy=srcY-iy;
      const clamp = (v,mx) => Math.min(v,mx);
      const v=Math.round(
        output[clamp(iy,OUTPUT_PX-1)*OUTPUT_PX+clamp(ix,OUTPUT_PX-1)]*(1-dx)*(1-dy)+
        output[clamp(iy,OUTPUT_PX-1)*OUTPUT_PX+clamp(ix+1,OUTPUT_PX-1)]*dx*(1-dy)+
        output[clamp(iy+1,OUTPUT_PX-1)*OUTPUT_PX+clamp(ix,OUTPUT_PX-1)]*(1-dx)*dy+
        output[clamp(iy+1,OUTPUT_PX-1)*OUTPUT_PX+clamp(ix+1,OUTPUT_PX-1)]*dx*dy
      );
      lowOutput[oy*LOW_PX+ox] = v;
      const i=(oy*LOW_PX+ox)*3;
      lowBytes[i]=(v>>16)&0xFF; lowBytes[i+1]=(v>>8)&0xFF; lowBytes[i+2]=v&0xFF;
    }
  }
  const lowBlob = new Blob([lowBytes], { type: 'application/octet-stream' });

  const lowNormalBytes = generateNormalMap(lowOutput, LOW_PX, mpp * (OUTPUT_PX / LOW_PX));
  const lowNormalBlob  = new Blob([lowNormalBytes], { type: 'application/octet-stream' });

  let blob;
  if (format === 'raw') {
    const bytes = new Uint8Array(OUTPUT_PX * OUTPUT_PX * 3);
    for (let i = 0; i < OUTPUT_PX*OUTPUT_PX; i++) {
      const v=output[i];
      bytes[i*3]=(v>>16)&0xFF; bytes[i*3+1]=(v>>8)&0xFF; bytes[i*3+2]=v&0xFF;
    }
    blob = new Blob([bytes], { type: 'application/octet-stream' });
  } else {
    const pixels = new Uint8ClampedArray(OUTPUT_PX*OUTPUT_PX*4);
    for (let i = 0; i < OUTPUT_PX*OUTPUT_PX; i++) {
      const v=output[i];
      pixels[i*4]=v&0xFF; pixels[i*4+1]=(v>>8)&0xFF; pixels[i*4+2]=(v>>16)&0xFF; pixels[i*4+3]=255;
    }
    const canvas=document.createElement('canvas');
    canvas.width=canvas.height=OUTPUT_PX;
    const ctx=canvas.getContext('2d');
    const imgData=ctx.createImageData(OUTPUT_PX,OUTPUT_PX);
    imgData.data.set(pixels);
    ctx.putImageData(imgData,0,0);
    blob=await new Promise(res=>canvas.toBlob(res,'image/png'));
  }

  return { blob, normalBlob, lowBlob, lowNormalBlob };
}

// ─── Overview/Mega 공통: rawBuf + crop 샘플러 반환 ───────
async function buildOverviewRawBuf(onStatus) {
  const OV_GRID_    = 9;
  const OVERVIEW_M_ = OV_GRID_ * GRID_N * TILE_SIZE_KM * 1000;
  const halfKm      = OVERVIEW_M_ / 2 / 1000;
  const centerPt    = turf.point([state.lng, state.lat]);
  const nwLng = turf.destination(centerPt, halfKm, 270, { units: 'kilometers' }).geometry.coordinates[0];
  const nwLat = turf.destination(centerPt, halfKm,   0, { units: 'kilometers' }).geometry.coordinates[1];
  const seLng = turf.destination(centerPt, halfKm,  90, { units: 'kilometers' }).geometry.coordinates[0];
  const seLat = turf.destination(centerPt, halfKm, 180, { units: 'kilometers' }).geometry.coordinates[1];

  const nwTileX = lng2tileF(nwLng, OVERVIEW_ZOOM);
  const nwTileY = lat2tileF(nwLat, OVERVIEW_ZOOM);
  const seTileX = lng2tileF(seLng, OVERVIEW_ZOOM);
  const seTileY = lat2tileF(seLat, OVERVIEW_ZOOM);

  const startX = Math.floor(nwTileX);
  const startY = Math.floor(nwTileY);
  const endX   = Math.ceil(seTileX);
  const endY   = Math.ceil(seTileY);
  const tilesW = endX - startX;
  const tilesH = endY - startY;

  const tileList = [];
  for (let ty = 0; ty < tilesH; ty++)
    for (let tx = 0; tx < tilesW; tx++)
      tileList.push({ tx: startX+tx, ty: startY+ty, col: tx, row: ty });

  if (onStatus) onStatus(`zoom${OVERVIEW_ZOOM}: ${tilesW}×${tilesH}=${tilesW*tilesH}장 다운로드 중...`);

  const pixelMap = new Map();
  await Promise.all(tileList.map(async ({ tx, ty, col, row }) => {
    const url = `https://api.mapbox.com/v4/mapbox.terrain-rgb/${OVERVIEW_ZOOM}/${tx}/${ty}@2x.pngraw?access_token=${MAPBOX_TOKEN}`;
    try {
      pixelMap.set(`${col},${row}`, await downloadPngToPixels(url));
    } catch(e) {
      console.warn(`overview 타일 ${tx},${ty} 실패:`, e.message);
    }
  }));

  if (onStatus) onStatus('rawBuf 합성 중...');
  await new Promise(r => setTimeout(r, 10));

  const rawW   = tilesW * MAPBOX_TILE_PX;
  const rawH   = tilesH * MAPBOX_TILE_PX;
  const rawBuf = new Int32Array(rawW * rawH);
  for (let row = 0; row < tilesH; row++) {
    for (let col = 0; col < tilesW; col++) {
      const px = pixelMap.get(`${col},${row}`);
      if (!px) continue;
      const ox = col * MAPBOX_TILE_PX, oy = row * MAPBOX_TILE_PX;
      for (let y = 0; y < MAPBOX_TILE_PX; y++)
        for (let x = 0; x < MAPBOX_TILE_PX; x++) {
          const si = (y * MAPBOX_TILE_PX + x) * 4;
          rawBuf[(oy+y)*rawW + (ox+x)] = rgbToVal(px[si], px[si+1], px[si+2]);
        }
    }
  }

  const cropX0  = tileF2px(nwTileX, startX);
  const cropY0  = tileF2px(nwTileY, startY);
  const cropX1  = tileF2px(seTileX, startX);
  const cropY1  = tileF2px(seTileY, startY);
  const cropPxW = cropX1 - cropX0;
  const cropPxH = cropY1 - cropY0;

  function sample(ox, oy, outW, outH) {
    const srcX = cropX0 + ox * cropPxW / (outW - 1);
    const srcY = cropY0 + oy * cropPxH / (outH - 1);
    const ix = Math.floor(srcX), iy = Math.floor(srcY);
    const dx = srcX - ix, dy = srcY - iy;
    let val = 0;
    for (let m = -1; m <= 2; m++) {
      const wy = cubicWeight(m - dy);
      if (wy === 0) continue;
      for (let n = -1; n <= 2; n++) {
        const cx = Math.max(0, Math.min(rawW-1, ix+n));
        const cy = Math.max(0, Math.min(rawH-1, iy+m));
        val += rawBuf[cy*rawW + cx] * cubicWeight(n - dx) * wy;
      }
    }
    return Math.max(0, Math.min(16777215, Math.round(val)));
  }

  return { sample, rawW, rawH };
}

// ─── Mega Map 다운로드 ────────────────────────────────────
const OV_GRID = 9;

async function startMegaMapDownload() {
  const btn      = document.getElementById('dl-btn-mega');
  const statusEl = document.getElementById('status-mega');
  setBothBtnsDisabled(true);
  statusEl.textContent = '준비 중...';
  statusEl.style.color = 'var(--muted)';

  try {
    const { sample } = await buildOverviewRawBuf(t => {
      statusEl.textContent = t;
    });

    const MEGA    = OV_GRID * OUTPUT_PX;
    const CELL_PX = OUTPUT_PX;

    statusEl.textContent = '9216×9216 PNG 생성 중...';
    await new Promise(r => setTimeout(r, 10));

    const canvas  = document.createElement('canvas');
    canvas.width  = canvas.height = MEGA;
    const ctx     = canvas.getContext('2d');
    const imgData = ctx.createImageData(MEGA, MEGA);
    const pixels  = imgData.data;

    for (let oy = 0; oy < MEGA; oy++) {
      for (let ox = 0; ox < MEGA; ox++) {
        const v  = sample(ox, oy, MEGA, MEGA);
        const pi = (oy * MEGA + ox) * 4;
        pixels[pi]   = (v >> 16) & 0xFF;
        pixels[pi+1] = (v >>  8) & 0xFF;
        pixels[pi+2] =  v        & 0xFF;
        pixels[pi+3] = 255;
      }
    }

    ctx.putImageData(imgData, 0, 0);

    // 각 셀: 반투명 보라색 채우기 + 테두리 + (col, row) 레이블
    const fontSize   = Math.max(24, Math.round(CELL_PX * 0.055));
    ctx.font         = `bold ${fontSize}px "Space Mono", monospace`;
    ctx.textAlign    = 'center';
    ctx.textBaseline = 'middle';

    for (let row = 0; row < OV_GRID; row++) {
      for (let col = 0; col < OV_GRID; col++) {
        const x = col * CELL_PX;
        const y = row * CELL_PX;

        // 반투명 보라색 fill (짙게)
        ctx.fillStyle = 'rgba(110, 0, 220, 0.52)';
        ctx.fillRect(x, y, CELL_PX, CELL_PX);

        // 셀 테두리
        ctx.strokeStyle = 'rgba(220, 150, 255, 0.90)';
        ctx.lineWidth   = 3;
        ctx.strokeRect(x, y, CELL_PX, CELL_PX);

        // 좌표 레이블 — 검정 배경 박스 + 흰 텍스트
        const label = `(${col},${OV_GRID - 1 - row})`;
        const cx    = x + CELL_PX / 2;
        const cy    = y + CELL_PX / 2;

        ctx.font = `bold ${fontSize}px "Space Mono", monospace`;

        // 텍스트 배경 박스
        const metrics  = ctx.measureText(label);
        const tw       = metrics.width;
        const th       = fontSize;
        const pad      = fontSize * 0.35;
        ctx.fillStyle  = 'rgba(0, 0, 0, 0.72)';
        ctx.fillRect(cx - tw/2 - pad, cy - th/2 - pad, tw + pad*2, th + pad*2);

        // 텍스트
        ctx.shadowColor   = 'rgba(0, 0, 0, 1)';
        ctx.shadowBlur    = 6;
        ctx.fillStyle     = '#ffffff';
        ctx.fillText(label, cx, cy);
        ctx.shadowBlur    = 0;
      }
    }

    // 외곽 테두리
    ctx.strokeStyle = 'rgba(220, 150, 255, 1.0)';
    ctx.lineWidth   = 5;
    ctx.strokeRect(0, 0, MEGA, MEGA);

    statusEl.textContent = 'PNG 인코딩 중... (잠시 기다려주세요)';
    await new Promise(r => setTimeout(r, 10));

    const tag = `${state.lat.toFixed(4)}_${state.lng.toFixed(4)}`;
    canvas.toBlob(blob => {
      const link = document.createElement('a');
      link.href  = URL.createObjectURL(blob);
      link.download = `megamap_9216_${tag}.png`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      statusEl.textContent = `✓ 9216×9216 · 82,944m × 82,944m`;
      statusEl.style.color = 'var(--accent)';
      setBothBtnsDisabled(false);
    }, 'image/png');

  } catch(e) {
    console.error(e);
    statusEl.textContent = '오류: ' + e.message;
    statusEl.style.color = 'var(--danger)';
    setBothBtnsDisabled(false);
  }
}

